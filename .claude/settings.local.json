{
  "permissions": {
    "allow": [
      "Bash(gh auth:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(C:\\Users\\80951\\miniconda3\\envs\\modelf\\python.exe:*)",
      "Bash(C:\\Users\\80951\\miniconda3\\envs\\modelf\\Scripts\\pip.exe:*)",
      "Bash(C:/Users/80951/miniconda3/envs/modelf/python.exe:*)",
      "Bash(C:/Users/80951/miniconda3/envs/modelf/Scripts/pip.exe:*)",
      "Bash(C:/Users/80951/miniconda3/condabin/conda.bat:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/Desktop/model-f && git pull 2>&1 | tail -5",
            "statusMessage": "Checking for updates..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "printf '# Last Modified\\n\\n**Time:** %s  \\n**Machine:** %s\\n' \"$(date '+%Y-%m-%d %H:%M:%S')\" \"$(hostname)\" > ~/Desktop/model-f/LAST_MODIFIED.md && cd ~/Desktop/model-f && git add -A && git commit -m \"auto snapshot $(date +%F_%T)\" && git push 2>&1 | tail -3"
          }
        ]
      }
    ]
  }
}
